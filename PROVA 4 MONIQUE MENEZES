// [JSIA-A06] Crie um programa que utiliza funções anônimas, arrow functions e funções de callback para gerenciar e processar uma lista de tarefas.
// Requisitos do Projeto:
// * Criação de Funções Anônimas:
//  - Use uma função anônima para adicionar tarefas a uma lista. A função deve ser atribuída a uma variável e permitir adicionar uma nova tarefa ao array de tarefas.

// * Uso de Arrow Functions:
//  - Implemente uma arrow function para listar todas as tarefas, exibindo cada tarefa com seu índice no console.

// * Funções de Callback:
//  - Crie uma função que receba outra função como callback. Essa função deve permitir executar diferentes operações com a lista de tarefas, como:
//  - Remover uma tarefa.
//  - Atualizar uma tarefa.
//  - Concluir uma tarefa.

// * Interação com o Usuário:
//  - Utilize métodos como prompt() para receber ações do usuário e exiba os resultados no console usando console.log(). 

let tarefas = [];

/* FUNÇÃO ANÔNIMA - ADICIONAR */
const adicionarTarefa = function (tarefa) {
    tarefas.push(tarefa);
    console.log("✔ Tarefa adicionada!");
};

/* ARROW FUNCTION - LISTAR */
const listarTarefas = () => {
    console.log("\n📋 LISTA DE TAREFAS:");

    if (tarefas.length === 0) {
        console.log("Nenhuma tarefa cadastrada.");
        return;
    }

    tarefas.forEach((tarefa, i) => {
        console.log(`${i}: ${tarefa}`);
    });
};

/* CALLBACK SIMPLES */
function executar(callback) {
    callback();
}

/* LOOP PRINCIPAL */
while (true) {
    let opcao = prompt(
        "1-Adicionar tarefa\n2-Listar tarefas\n3-Remover tarefa\n4-Atualizar tarefas\n5-Concluir\n6-Sair"
    );

    if (opcao === "1") {
        let t = prompt("Digite a tarefa:");
        adicionarTarefa(t);
    }

    else if (opcao === "2") {
        executar(listarTarefas);
    }

    else if (opcao === "3") {
        executar(() => {
            let i = Number(prompt("Índice para remover:"));

            if (i >= 0 && i < tarefas.length) {
                tarefas.splice(i, 1);
                console.log("🗑 Removida!");
            } else {
                console.log("Índice inválido!");
            }
        });
    }

    else if (opcao === "4") {
        executar(() => {
            let i = Number(prompt("Índice para atualizar:"));
            let novo = prompt("Nova tarefa:");

            if (i >= 0 && i < tarefas.length) {
                tarefas[i] = novo;
                console.log("✏ Atualizada!");
            } else {
                console.log("Índice inválido!");
            }
        });
    }

    else if (opcao === "5") {
        executar(() => {
            let i = Number(prompt("Índice para concluir:"));

            if (i >= 0 && i < tarefas.length) {
                tarefas[i] = "✅ " + tarefas[i];
                console.log("Concluída!");
            } else {
                console.log("Índice inválido!");
            }
        });
    }

    else if (opcao === "6") {
        console.log("Saindo...");
        break;
    }

    else {
        console.log("Opção inválida!");
    }
}
